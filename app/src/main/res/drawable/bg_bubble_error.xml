<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bordure gauche rouge -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/hasan_error_bubble_border" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Fond décalé de 4dp à gauche pour laisser la bordure visible -->
    <item android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/hasan_error_bubble_bg" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
