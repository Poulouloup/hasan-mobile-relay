<?xml version="1.0" encoding="utf-8"?>
<!-- Scanner QR minimal (pairing relay) — juste la preview caméra + un texte d'aide.
     Design soigné laissé à l'étape 9 (refonte UI). -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hasan_bg_primary">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@color/hasan_bg_primary"
        android:textColor="@color/hasan_text_primary"
        android:text="@string/qr_scanner_hint" />

</FrameLayout>
