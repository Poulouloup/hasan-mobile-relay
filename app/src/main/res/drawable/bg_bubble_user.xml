<?xml version="1.0" encoding="utf-8"?>
<!-- Fond bulle message utilisateur — bord gauche rouge accent -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bubble_user_bg" />
            <corners android:radius="@dimen/radius_bubble"
                android:topLeftRadius="4dp" />
        </shape>
    </item>
    <item android:left="0dp" android:right="0dp"
          android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="0dp" android:color="@android:color/transparent" />
            <corners android:radius="@dimen/radius_bubble"
                android:topLeftRadius="4dp" />
        </shape>
    </item>
</layer-list>
