<?xml version="1.0" encoding="utf-8"?>
<!-- Activité racine — BottomNavigationView + FragmentContainerView -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/hasan_bg_primary">

    <!-- Zone de contenu principale — fragments Chat et Réglages -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Séparateur fin au-dessus de la barre -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hasan_border" />

    <!-- Bottom Navigation Bar — Compose (voir HasanBottomNav.kt), bordure haute
         accent sur l'onglet actif, fidèle au mockup (pas de pilule Material). -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/bottomNavCompose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
