<?xml version="1.0" encoding="utf-8"?>
<!-- Bulle Hasan — fond sombre avec bordure gauche rouge -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bordure gauche rouge 4dp -->
    <item android:left="0dp" android:right="0dp" android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/hasan_accent" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Fond principal -->
    <item android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/hasan_bg_card" />
            <corners android:topRightRadius="12dp" android:bottomRightRadius="12dp"
                android:topLeftRadius="0dp" android:bottomLeftRadius="0dp" />
        </shape>
    </item>
</layer-list>
