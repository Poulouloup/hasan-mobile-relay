<?xml version="1.0" encoding="utf-8"?>
<!-- Fragment Chat principal — style Claude/ChatGPT avec BottomNav -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootConversation"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hasan_bg_primary">

    <!-- ── Header Hasan — avatar + titre + indicateur connexion ──────────── -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/hasan_bg_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Avatar rond avec logo Hasan -->
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_avatar"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/app_name" />

        <!-- Titre + sous-titre Hermes Agent -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHasanTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/header_title"
                android:textColor="@color/hasan_accent"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvHasanSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/header_subtitle"
                android:textColor="@color/hasan_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <!-- Bouton mode light -->
        <ImageButton
            android:id="@+id/btnLightMode"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_light_mode"
            android:tint="@color/hasan_text_secondary"
            android:padding="6dp"
            android:contentDescription="@string/light_mode_toggle" />

        <!-- Indicateur de connexion — point coloré + texte statut -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/viewConnectionDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_status"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/cd_connection_dot" />

            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/header_status_disconnected"
                android:textColor="@color/hasan_text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Séparateur sous le header -->
    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/hasan_border"
        app:layout_constraintTop_toBottomOf="@id/chatHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zone de conversation scrollable -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toTopOf="@id/inputZone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zone de saisie en bas -->
    <LinearLayout
        android:id="@+id/inputZone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/hasan_bg_primary"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- MODE VOCAL — onde sonore + statut -->
        <RelativeLayout
            android:id="@+id/voiceModeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible">

            <!-- Zone onde sonore animée -->
            <LinearLayout
                android:id="@+id/waveContainer"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center">

                <View android:id="@+id/waveBar1"
                    android:layout_width="4dp" android:layout_height="28dp"
                    android:layout_marginEnd="6dp"
                    android:background="@color/hasan_accent"
                    android:transformPivotY="14dp" />
                <View android:id="@+id/waveBar2"
                    android:layout_width="4dp" android:layout_height="28dp"
                    android:layout_marginEnd="6dp"
                    android:background="@color/hasan_accent"
                    android:transformPivotY="14dp" />
                <View android:id="@+id/waveBar3"
                    android:layout_width="4dp" android:layout_height="28dp"
                    android:layout_marginEnd="6dp"
                    android:background="@color/hasan_accent"
                    android:transformPivotY="14dp" />
                <View android:id="@+id/waveBar4"
                    android:layout_width="4dp" android:layout_height="28dp"
                    android:layout_marginEnd="6dp"
                    android:background="@color/hasan_accent"
                    android:transformPivotY="14dp" />
                <View android:id="@+id/waveBar5"
                    android:layout_width="4dp" android:layout_height="28dp"
                    android:background="@color/hasan_accent"
                    android:transformPivotY="14dp" />

            </LinearLayout>

            <!-- Statut vocal centré -->
            <TextView
                android:id="@+id/tvVoiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/waveContainer"
                android:layout_centerHorizontal="true"
                android:text="@string/status_wake_word"
                android:textColor="@color/hasan_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <!-- Bouton clavier en bas à droite -->
            <ImageButton
                android:id="@+id/btnSwitchToText"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_below="@id/waveContainer"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_keyboard"
                android:tint="@color/hasan_text_secondary"
                android:contentDescription="@string/btn_switch_text" />

            <!-- Bouton Stop TTS — visible uniquement pendant la lecture vocale -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStopTts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/waveContainer"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="4dp"
                android:text="⏹ Stop"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:visibility="gone"
                app:backgroundTint="@color/hasan_accent"
                app:cornerRadius="20dp"
                style="@style/Widget.MaterialComponents.Button" />

        </RelativeLayout>

        <!-- MODE TEXTE — TextField + micro + envoi -->
        <LinearLayout
            android:id="@+id/textModeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <!-- Champ de saisie arrondi -->
            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:background="@drawable/bg_chat_input"
                android:paddingStart="18dp"
                android:paddingEnd="48dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:textColor="@color/hasan_text_primary"
                android:textColorHint="@color/hasan_text_hint"
                android:hint="@string/hint_message"
                android:textSize="15sp"
                android:maxLines="4"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="flagNoEnterAction"
                android:gravity="center_vertical" />

            <!-- Bouton micro rond rouge -->
            <ImageButton
                android:id="@+id/btnSwitchToVoice"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_round_button"
                android:src="@drawable/ic_mic"
                android:tint="@color/white"
                android:padding="12dp"
                android:contentDescription="@string/cd_mic_button" />

            <!-- Bouton envoi rond gris -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_round_button_gray"
                android:src="@drawable/ic_arrow_up"
                android:tint="@color/hasan_text_primary"
                android:padding="12dp"
                android:contentDescription="@string/cd_send_button" />

        </LinearLayout>

    </LinearLayout>

    <!-- Ring light wake word — flash rouge translucide sur tout l'écran -->
    <View
        android:id="@+id/wakeWordRingLight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/hasan_accent"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
