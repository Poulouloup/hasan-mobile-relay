<?xml version="1.0" encoding="utf-8"?>
<!-- Item liste sessions — nom + date + badge Active -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/hasan_bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/hasan_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Indicateur session active (point rouge) -->
        <View
            android:id="@+id/viewActiveDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_status"
            android:layout_marginEnd="12dp"
            android:visibility="invisible" />

        <!-- Nom + date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSessionName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hasan_text_primary"
                android:textSize="15sp"
                android:textStyle="normal" />

            <TextView
                android:id="@+id/tvSessionDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/hasan_text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Badge "Active" -->
        <TextView
            android:id="@+id/tvActiveBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_active_bg"
            android:text="Active"
            android:textColor="@color/hasan_accent"
            android:textSize="11sp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
