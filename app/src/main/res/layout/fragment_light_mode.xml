<?xml version="1.0" encoding="utf-8"?>
<!-- Mode Light — interface épurée pour utilisation mains libres -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hasan_bg_primary">

    <!-- Logo Hasan — haut gauche -->
    <ImageView
        android:id="@+id/ivLightLogo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_avatar"
        android:layout_margin="24dp"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Statut vocal — sous le logo -->
    <TextView
        android:id="@+id/tvLightStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/status_wake_word"
        android:textColor="@color/hasan_text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivLightLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dernier message Hasan — sous le statut -->
    <TextView
        android:id="@+id/tvLightLastMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/hasan_text_secondary"
        android:textSize="18sp"
        android:gravity="center"
        android:maxLines="3"
        android:ellipsize="end"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvLightStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Gros bouton micro — centré verticalement et horizontalement -->
    <ImageButton
        android:id="@+id/btnLightMic"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_round_button"
        android:src="@drawable/ic_mic"
        android:tint="@color/white"
        android:padding="24dp"
        android:scaleType="fitCenter"
        android:contentDescription="@string/cd_mic_button"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bouton mute/unmute TTS — bas gauche -->
    <ImageButton
        android:id="@+id/btnLightMute"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_volume_on"
        android:tint="@color/hasan_text_secondary"
        android:padding="8dp"
        android:contentDescription="@string/settings_tts_volume"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bouton quitter Light Mode — bas droite -->
    <ImageButton
        android:id="@+id/btnExitLightMode"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_close"
        android:tint="@color/hasan_text_secondary"
        android:padding="8dp"
        android:contentDescription="@string/light_mode_exit"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
