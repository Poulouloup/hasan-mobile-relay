<?xml version="1.0" encoding="utf-8"?>
<!-- Fragment MCP — liste des capabilities togglables (voir McpFragment.kt).
     Hébergé comme child fragment dans SettingsFragment (étape 9.2, section
     "Orchestrateur MCP") : layout_height wrap_content et pas de ScrollView propre
     — le ScrollView parent de fragment_settings.xml gère déjà le défilement, un
     second ScrollView imbriqué casserait le scroll (hauteur non bornée en wrap_content). -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/hasan_bg_primary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ═══════════════ CAPABILITIES ═══════════════ -->
            <TextView
                style="@style/Hasan.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mcp_section_capabilities" />

            <android.widget.GridLayout
                android:id="@+id/containerCapabilities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:paddingHorizontal="10dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

</LinearLayout>
