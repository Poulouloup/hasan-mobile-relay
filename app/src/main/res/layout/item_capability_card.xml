<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/hasan_bg_card"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/hasan_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Ligne haut : icône + bouton info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/ivCapabilityIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:scaleType="fitStart"
                android:tint="@color/hasan_accent"
                tools:src="@drawable/ic_cap_battery" />

            <ImageButton
                android:id="@+id/btnCapabilityInfo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_info"
                android:tint="@color/hasan_text_secondary"
                android:contentDescription="Info" />

        </LinearLayout>

        <!-- Nom -->
        <TextView
            android:id="@+id/tvCapabilityName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/hasan_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            tools:text="Batterie" />

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/hasan_border"
            android:layout_marginBottom="10dp" />

        <!-- Toggle ON/OFF -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Activer"
                android:textColor="@color/hasan_text_secondary"
                android:textSize="11sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchCapability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/hasan_accent"
                app:trackTint="@color/hasan_accent_dim" />

        </LinearLayout>

        <!-- Toggle Auth required -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Confirmation"
                android:textColor="@color/hasan_text_secondary"
                android:textSize="11sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAuthRequired"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/hasan_accent"
                app:trackTint="@color/hasan_accent_dim" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
