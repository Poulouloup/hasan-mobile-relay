<?xml version="1.0" encoding="utf-8"?>
<!-- Glyphe de marque du header — reproduit exactement le trait SVG du mockup
     (docs/design/hasan-mockup-v2.html, .brand-mark svg) : M4 20 L9 6 L12 14 L15 6 L20 20,
     tracé (stroke, pas fill) en #0A0A0A sur le fond accent du brand-mark. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#00000000"
        android:strokeColor="#0A0A0A"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M4,20 L9,6 L12,14 L15,6 L20,20" />
</vector>
