<?xml version="1.0" encoding="utf-8"?>
<!-- Fragment Réglages — Compose intégral (SettingsScreen), voir SettingsFragment.kt.
     Le ComposeView réel est construit directement en code dans onCreateView() (pattern
     nécessaire pour héberger McpFragment via un FrameLayout créé par la factory AndroidView),
     ce layout XML n'est donc plus inflaté — conservé comme trace du composant racine
     attendu par convention avec les autres écrans Compose du projet (fragment_activity.xml). -->
<androidx.compose.ui.platform.ComposeView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsComposeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />
